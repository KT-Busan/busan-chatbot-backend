# OpenAI
OPENAI_API_KEY=sk-...

# Flask
PORT=5001
FLASK_ENV=development

# CORS (쉼표로 구분, 공백 없이)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000,https://kt-busan.github.io

# 배포 환경 (Render 디스크 경로, 로컬에서는 불필요)
# RENDER_DISK_PATH=/var/data

# 크롤링 대상
CRAWLER_BASE_URL=https://young.busan.go.kr

# 관리자 강제 크롤링 갱신용 토큰 (/api/admin/refresh-crawl 호출 시 X-Admin-Token 헤더로 전달)
# GitHub Actions에서는 동일한 값을 Secrets(ADMIN_REFRESH_TOKEN)로 등록해서 사용한다
ADMIN_REFRESH_TOKEN=change-me-to-a-random-secret

# DB (미설정 시 SQLite 기본값 사용)
# DATABASE_URL=sqlite:///instance/chatbot.db
